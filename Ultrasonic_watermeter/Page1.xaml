<Page x:Class="Ultrasonic_watermeter.Page1"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Ultrasonic_watermeter"
      xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"

      mc:Ignorable="d" 
      d:DesignHeight="800" d:DesignWidth="1245" d:Background="White"
      Title="Page1">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0"
              VerticalAlignment="Center">
            
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <materialDesign:Card Grid.Column="0"
                                 BorderBrush="Gray" 
                                 BorderThickness="1"
								 Margin="20"
								 Padding="10,0,10,0">
                <StackPanel Orientation="Horizontal" 
                            HorizontalAlignment="Left">

                <RadioButton x:Name="radWaterUsed"
                             Content="Lượng nước sử dụng"
                             Click="BtnWaterUsed_Click"
                             Margin="5"
                             GroupName="grpType"/>

                <RadioButton x:Name="radMeterReading"
                             Content="Chỉ số đồng hồ nước"
                             Click="BtnMeterReading_Click"
                             Margin="5"
                             GroupName="grpType"/>
                </StackPanel>
            </materialDesign:Card>
            
            <Grid Grid.Column="2"
                  Margin="20">
                <StackPanel Orientation="Horizontal" 
                            HorizontalAlignment="Right">
                    <Button materialDesign:ButtonAssist.CornerRadius="5"
                            x:Name="btnImportData"
                            Content="📥 Nhập dữ liệu"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Width="140"
                            FontSize="14"
                            Margin="5"
                            Click="btnImportData_Click"/>
                    <Button materialDesign:ButtonAssist.CornerRadius="5"
                            x:Name="btnExportData"
                            Content="📤 Xuất dữ liệu"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Width="140"
                            FontSize="14"
                            Margin="5"
                            Click="btnExportData_Click"/>
                    <Button materialDesign:ButtonAssist.CornerRadius="5"
                            x:Name="btnReadData"
                            Content="📄 Đọc dữ liệu"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Width="140"
                            FontSize="14"
                            Margin="5"
                            Click="btnReadData_Click"/>
                </StackPanel>
            </Grid>
        </Grid>
        
        <Border Grid.Row="1"
                CornerRadius="10"
                Background="White"
                BorderThickness="2"
                Margin="20,0,20,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           x:Name="ChartTitle"
                           FontSize="18"
                           FontWeight="Bold" 
                           HorizontalAlignment="Center"
                           Margin="20"/>
                <lvc:CartesianChart Grid.Row="1"
                                    x:Name="WaterChart"/>
            </Grid>
        </Border>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal" 
                    HorizontalAlignment="Left"
                    Margin="20">
            <materialDesign:Card BorderBrush="Gray" 
                                 BorderThickness="1" 
							     Padding="10">
                <TextBlock x:Name="txtSumWaterUsed"
                           Text="Tổng lượng nước sử dụng: ------"
                           Style="{DynamicResource MaterialDesignBody2TextBlock}"
                           TextAlignment="Center"/>
            </materialDesign:Card>
        </StackPanel>
    </Grid>
</Page>
