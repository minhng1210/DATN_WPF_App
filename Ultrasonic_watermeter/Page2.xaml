<Page x:Class="Ultrasonic_watermeter.Page2"
	  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
	  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	  xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
	  xmlns:oxy="http://oxyplot.org/wpf"
	  mc:Ignorable="d" 
	  d:DesignHeight="800" d:DesignWidth="1245" d:Background="White"
	  Title="Real-time Sensor Data">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="345"/>
        </Grid.RowDefinitions>
        <!-- Chart Section -->
        <Grid Grid.Row="0"
              Margin="10,0,0,10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" >
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="📊 Biểu đồ lưu lượng nước" 
                               Style="{DynamicResource MaterialDesignHeadline6TextBlock}"
                               Margin="5"/>
                    <StackPanel Grid.Column="1" 
                                Orientation="Horizontal" 
                                HorizontalAlignment="Right" 
                                Margin="0,0,10,0">
                        <Button x:Name="btnStart"
								Content="▶ Bắt đầu" 
								materialDesign:ButtonAssist.CornerRadius="5"
                                Width="100"
								Margin="5" 
								Click="BtnStart_Click"
								Background="LightGreen"
								Foreground="Black"/>
                        <Button x:Name="btnStop"
								Content="⏹ Dừng" 
								materialDesign:ButtonAssist.CornerRadius="5"
                                Width="100"
								Margin="5"
								Click="BtnStop_Click" 
								Background="LightCoral"
								Foreground="Black"
								IsEnabled="False"/>
                        <Button x:Name="btnReset"
								Content="🔄 Đặt lại" 
								materialDesign:ButtonAssist.CornerRadius="5"
                                Width="100"
								Margin="5"
								Click="BtnReset_Click" 
								Background="LightGray"
								Foreground="Black"/>
                        <Button x:Name="btnImport"
								Content="📥 Nhập dữ liệu" 
								materialDesign:ButtonAssist.CornerRadius="5"
                                Width="140"
								Margin="5"
								Click="BtnImport_Click" 
								Background="LightBlue"
								Foreground="Black"/>
                        <Button x:Name="btnExport"
								Content="📤 Xuất dữ liệu" 
								materialDesign:ButtonAssist.CornerRadius="5"
                                Width="140"
								Margin="5"
								Click="BtnExport_Click" 
								Background="LightBlue"
								Foreground="Black"/>
                    </StackPanel>
                </Grid>

                <oxy:PlotView Grid.Row="1" 
                              x:Name="RealTimePlot" 
                              Model="{Binding PlotModel, Mode=OneWay}"/>
                <Button Grid.Row="1" 
                        x:Name="btnRefresh"
						Content="🔄" 
                        Style="{StaticResource MaterialDesignFlatButton}"
						Click="BtnRefresh_Click"
						Foreground="Black" 
                        BorderThickness="0"
                        Margin="65,10,26,0"
                        BorderBrush="Transparent"
                        HorizontalAlignment="Right" 
                        VerticalAlignment="Top"/>
            </Grid>
        </Grid>

        <!-- Statistics Panel -->
        <Grid Grid.Row="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0"
                            Margin="10"
                            Width="360">
                    <materialDesign:Card BorderBrush="Gray" 
                                         BorderThickness="1"
										 Margin="5" 
										 Padding="5">
                        <TextBlock x:Name="txtTemperature" 
								   Text="Nhiệt độ: --" 
								   Style="{DynamicResource MaterialDesignBody2TextBlock}"
								   TextAlignment="Center"/>
                    </materialDesign:Card>
                    <materialDesign:Card BorderBrush="Gray" 
                                         BorderThickness="1"
										 Margin="5" 
										 Padding="5">
                        <TextBlock x:Name="txtTimeUp" 
								   Text="Thời gian truyền xuôi: --" 
								   Style="{DynamicResource MaterialDesignBody2TextBlock}"
								   TextAlignment="Center"/>
                    </materialDesign:Card>
                    <materialDesign:Card BorderBrush="Gray" 
                                         BorderThickness="1"
										 Margin="5" 
										 Padding="5">
                        <TextBlock x:Name="txtTimeDown" 
								   Text="Thời gian truyền ngược: --" 
								   Style="{DynamicResource MaterialDesignBody2TextBlock}"
								   TextAlignment="Center"/>
                    </materialDesign:Card>
                    <materialDesign:Card BorderBrush="Gray" 
                                         BorderThickness="1"
										 Margin="5" 
										 Padding="5">
                        <TextBlock x:Name="txtCurrentFlowValue" 
								   Text="Lưu lượng hiện tại: --" 
								   Style="{DynamicResource MaterialDesignBody2TextBlock}"
								   TextAlignment="Center"/>
                    </materialDesign:Card>
                    <materialDesign:Card BorderBrush="Gray" 
                                         BorderThickness="1"
										 Margin="5" 
										 Padding="5">
                        <TextBlock x:Name="txtMinFlowValue" 
								   Text="Lưu lượng nhỏ nhất: --" 
                                   Style="{DynamicResource MaterialDesignBody2TextBlock}"
                                   TextAlignment="Center"/>
                    </materialDesign:Card>
                    <materialDesign:Card BorderBrush="Gray" 
                                         BorderThickness="1"
                                         Margin="5" 
                                         Padding="5">
                        <TextBlock x:Name="txtAvgFlowValue" 
                                   Text="Lưu lượng trung bình: --" 
                                   Style="{DynamicResource MaterialDesignBody2TextBlock}"
                                   TextAlignment="Center"/>
                    </materialDesign:Card>
                    <materialDesign:Card BorderBrush="Gray" 
                                         BorderThickness="1"
                                         Margin="5" 
                                         Padding="5">
                        <TextBlock x:Name="txtMaxFlowValue" 
                                   Text="Lưu lượng lớn nhất: --" 
                                   Style="{DynamicResource MaterialDesignBody2TextBlock}"
                                   TextAlignment="Center"/>
                    </materialDesign:Card>
                    <materialDesign:Card BorderBrush="Gray" 
                                         BorderThickness="1"
                                         Margin="5" 
                                         Padding="5">
                        <TextBlock x:Name="txtTotalWaterUsage" 
                                   Text="Tổng lượng nước sử dụng: --" 
                                   Style="{DynamicResource MaterialDesignBody2TextBlock}"
                                   TextAlignment="Center"/>
                    </materialDesign:Card>
                </StackPanel>
                <Grid Grid.Column="1" Margin="10">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" >
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="📟 Serial Terminal" 
                                       Style="{DynamicResource MaterialDesignHeadline6TextBlock}" 
                                       Margin="5"/>
                            <Button Grid.Column="1"
                                    x:Name="btnClear"
								    Content="Xóa" 
								    materialDesign:ButtonAssist.CornerRadius="5"
                                    Width="100"
								    Margin="0,0,5,0"
								    Click="BtnClear_Click" 
								    Background="LightGray"
								    Foreground="Black" 
                                    HorizontalAlignment="Right"/>
                        </Grid>

                        <ListBox Grid.Row="1" 
                                 x:Name="lstTerminal" 
                                 Margin="5" 
                                 Background="Black" 
                                 Foreground="Lime" 
                                 FontFamily="Consolas" 
                                 FontSize="10">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" 
                                               TextWrapping="Wrap"/>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <Grid Grid.Row="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="txtSendCommand" 
                                     Grid.Column="0" Margin="5" 
                                     Height="30" 
                                     FontSize="12" 
							         KeyDown="TxtSendCommand_KeyDown"/>
                            <Button x:Name="btnSend" 
                                    Grid.Column="1" 
                                    Content="Gửi" 
                                    Width="80" 
                                    Height="30" 
                                    Margin="5" 
							        Click="BtnSend_Click" 
                                    Background="SkyBlue"/>
                        </Grid>
                    </Grid>
                </Grid>
            </Grid>
        </Grid>
        <!-- Serial Terminal -->
    </Grid>
</Page>